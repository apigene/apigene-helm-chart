# Local / on-prem example — works with k3d or any existing Kubernetes cluster.
#
# Local access (add to /etc/hosts): 127.0.0.1 apigene.localtest
# Then: kubectl port-forward -n apigene svc/nginx 8080:8080
# Open: http://apigene.localtest:8080

tenant_name  = "local"
fqdn         = "apigene.localtest"
image_tag    = "5.2.0"
public_url_port = 8080
copilot_internal_public_url_host_alias = true

# For k3d/local testing without real TLS:
enable_tls         = false
use_staging_issuer = true
aws_nlb            = false
install_storage_class = false

# install_addons = true   # installs nginx-ingress + cert-manager
